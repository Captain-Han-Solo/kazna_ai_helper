
#Область ОбработчикиСобытийФормы

&НаСервере
&После("ПриСозданииНаСервере")
Процедура kh_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)

	kh_ДобавитьКомандуАнализаНазначенияПлатежа();
	kh_УстановитьДоступностьКнопкиАнализа();

КонецПроцедуры

&НаКлиенте
&После("ПриОткрытии")
Процедура kh_ПриОткрытииПосле(Отказ)

	kh_ОбновитьДоступностьКнопкиАнализа();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура kh_АнализНазначенияПлатежа(Команда)

	Если ЭтаФорма.Объект.РасшифровкаПлатежа.Количество() > 0 Тогда

		Оповещение = Новый ОписаниеОповещения("kh_АнализНазначенияПлатежаПодтверждениеЗавершение", ЭтотОбъект);
		ТекстВопроса = НСтр("ru = 'Текущая расшифровка платежа будет заменена результатом анализа. Продолжить?'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		Возврат;

	КонецЕсли;

	kh_ВыполнитьАнализНазначенияПлатежа();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура kh_ДобавитьКомандуАнализаНазначенияПлатежа()

	ИмяКоманды = "kh_АнализНазначенияПлатежа";
	ИмяКнопки = "kh_КнопкаАнализНазначенияПлатежа";

	Если Команды.Найти(ИмяКоманды) <> Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Элементы.Найти(ИмяКнопки) <> Неопределено Тогда
		Возврат;
	КонецЕсли;

	КоманднаяПанельФормы = Элементы.РасшифровкаПлатежа.КоманднаяПанель;
    
	Если КоманднаяПанельФормы = Неопределено Тогда
		Возврат;
	КонецЕсли;

	НоваяКоманда = Команды.Добавить(ИмяКоманды);
	НоваяКоманда.Заголовок = НСтр("ru = 'Заполнить расшифровку (ИИ)'");
	НоваяКоманда.Подсказка = НСтр("ru = 'Запустить AI-анализ назначения платежа и заполнить расшифровку'");
	НоваяКоманда.Действие = "kh_АнализНазначенияПлатежа";

	Кнопка = Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"), КоманднаяПанельФормы);
	Кнопка.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = ИмяКоманды;
	Кнопка.Заголовок = НоваяКоманда.Заголовок;
	Кнопка.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВКоманднойПанели;

КонецПроцедуры

&НаСервере
Процедура kh_УстановитьДоступностьКнопкиАнализа()

	Кнопка = Элементы.Найти("kh_КнопкаАнализНазначенияПлатежа");

	Если Кнопка = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	Кнопка.Доступность = kh_ДоступенРучнойАнализ(ДокументОбъект.Контрагент, ДокументОбъект.НазначениеПлатежа);

КонецПроцедуры

&НаКлиенте
Процедура kh_ОбновитьДоступностьКнопкиАнализа()

	Кнопка = Элементы.Найти("kh_КнопкаАнализНазначенияПлатежа");

	Если Кнопка = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Кнопка.Доступность = kh_ДоступенРучнойАнализ(ЭтаФорма.Объект.Контрагент, ЭтаФорма.Объект.НазначениеПлатежа);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция kh_ДоступенРучнойАнализ(Контрагент, НазначениеПлатежа)

	Возврат ЗначениеЗаполнено(Контрагент) И Не ПустаяСтрока(НазначениеПлатежа);

КонецФункции

&НаКлиенте
Процедура kh_АнализНазначенияПлатежаПодтверждениеЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт

	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	kh_ВыполнитьАнализНазначенияПлатежа();

КонецПроцедуры

&НаКлиенте
Процедура kh_ВыполнитьАнализНазначенияПлатежа()

	Если Не kh_ДоступенРучнойАнализ(ЭтаФорма.Объект.Контрагент, ЭтаФорма.Объект.НазначениеПлатежа) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для анализа заполните контрагента и назначение платежа.'"));
		Возврат;
	КонецЕсли;

	Состояние(НСтр("ru = 'Выполняется AI-анализ назначения платежа...'"));

	РезультатАнализа = kh_АнализНазначенияПлатежаНаСервере();

	Состояние("");

	Если РезультатАнализа.Записан Тогда
		Модифицированность = Ложь;
		ТекстСообщения = НСтр("ru = 'Анализ выполнен, документ записан.'");
	Иначе
		Модифицированность = Истина;
		ТекстСообщения = НСтр("ru = 'Анализ выполнен. Запишите документ, чтобы сохранить результат.'");
	КонецЕсли;

	kh_ОбновитьДоступностьКнопкиАнализа();

	ПоказатьОповещениеПользователя(
		НСтр("ru = 'AI-анализ назначения платежа'"),
		,
		ТекстСообщения,
		БиблиотекаКартинок.Информация32);

КонецПроцедуры

&НаСервере
Функция kh_АнализНазначенияПлатежаНаСервере()

	ДокументОбъект = РеквизитФормыВЗначение("Объект");

	kh_ОбработкаПоступленияНаРасчетныйСчет.ВыполнитьАнализИЗаполнение(ДокументОбъект, Истина);

	Результат = Новый Структура;
	Результат.Вставить("Записан", Ложь);

	Если Не ДокументОбъект.ЭтоНовый() Тогда

		kh_ОбработкаПоступленияНаРасчетныйСчет.ЗаписатьДокументПослеРучногоАнализа(ДокументОбъект);
		Результат.Записан = Истина;

	КонецЕсли;

	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");

	Возврат Результат;

КонецФункции

#КонецОбласти
