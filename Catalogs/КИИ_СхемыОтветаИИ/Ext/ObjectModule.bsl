#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Валидация табличной части Свойства при записи схемы:
//  * Имя не пустое.
//  * Имя не содержит символ точки (точка зарезервирована за иерархией путей JSON).
//  * ФорматЗначения принадлежит whitelist (см. Справочники.КИИ_СхемыОтветаИИ.ДопустимыеФорматыЗначения).
//
// При нарушении — ВызватьИсключение со списком проблемных строк ТЧ, что прерывает запись.
//
Процедура ПередЗаписью(Отказ)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Нарушения = Новый Массив;

	ДопустимыеФорматы = Справочники.КИИ_СхемыОтветаИИ.ДопустимыеФорматыЗначения();
	КартаДопустимыхФорматов = Новый Соответствие;

	Для Каждого Формат Из ДопустимыеФорматы Цикл
		КартаДопустимыхФорматов.Вставить(Формат, Истина);
	КонецЦикла;

	Для Каждого СтрокаСвойства Из Свойства Цикл

		Имя = СокрЛП(СтрокаСвойства.Имя);

		Если ПустаяСтрока(Имя) Тогда

			ШаблонСообщения = НСтр("ru = 'Строка %1: не задано имя свойства схемы.'");
			Нарушения.Добавить(СтрШаблон(ШаблонСообщения, СтрокаСвойства.НомерСтроки));

		ИначеЕсли СтрНайти(Имя, ".") > 0 Тогда

			ШаблонСообщения = НСтр("ru = 'Строка %1: имя ""%2"" содержит точку (зарезервирована за иерархией путей JSON).'");
			Нарушения.Добавить(СтрШаблон(ШаблонСообщения, СтрокаСвойства.НомерСтроки, Имя));

		КонецЕсли;

		ФорматЗначения = СокрЛП(СтрокаСвойства.ФорматЗначения);
		Если КартаДопустимыхФорматов.Получить(ФорматЗначения) = Неопределено Тогда

			ШаблонСообщения = НСтр("ru = 'Строка %1: формат значения ""%2"" не поддерживается. Допустимые: %3.'");
			Допустимые = СтрСоединить(ПредставлениеДопустимыхФорматов(ДопустимыеФорматы), ", ");
			Нарушения.Добавить(СтрШаблон(
				ШаблонСообщения,
				СтрокаСвойства.НомерСтроки,
				ФорматЗначения,
				Допустимые));

		КонецЕсли;

	КонецЦикла;

	Если Нарушения.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(Нарушения, Символы.ПС);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПредставлениеДопустимыхФорматов(ДопустимыеФорматы)

	Представления = Новый Массив;

	Для Каждого Формат Из ДопустимыеФорматы Цикл

		Если ПустаяСтрока(Формат) Тогда
			Представления.Добавить(НСтр("ru = '(пусто)'"));
		Иначе
			Представления.Добавить(СтрШаблон("""%1""", Формат));
		КонецЕсли;

	КонецЦикла;

	Возврат Представления;

КонецФункции

#КонецОбласти

#КонецЕсли
