#Область ПрограммныйИнтерфейс

// Возвращает доверенный код валидации по ссылке на элемент справочника.
//
// Параметры:
//  Валидатор - СправочникСсылка.КИИ_ВалидаторыОтветаИИ
//
// Возвращаемое значение:
//  Строка
//
Функция КодВалидации(Валидатор) Экспорт

	Если Не ЗначениеЗаполнено(Валидатор) Тогда
		Возврат "";
	КонецЕсли;

	Коды = КодыВалидации(МассивВалидаторов(Валидатор));

	Возврат Коды.Получить(Валидатор);

КонецФункции

// Возвращает соответствие ссылок валидаторов и их кода валидации.
//
// Параметры:
//  Валидаторы - Массив из СправочникСсылка.КИИ_ВалидаторыОтветаИИ
//
// Возвращаемое значение:
//  Соответствие из Ключ: СправочникСсылка.КИИ_ВалидаторыОтветаИИ, Значение: Строка
//
Функция КодыВалидации(Валидаторы) Экспорт

	Результат = Новый Соответствие;

	Если Валидаторы = Неопределено Или Валидаторы.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	УникальныеСсылки = Новый Массив;
	КэшУникальности = Новый Соответствие;

	Для Каждого Валидатор Из Валидаторы Цикл

		Если Не ЗначениеЗаполнено(Валидатор) Тогда
			Продолжить;
		КонецЕсли;

		Если КэшУникальности.Получить(Валидатор) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		КэшУникальности.Вставить(Валидатор, Истина);
		УникальныеСсылки.Добавить(Валидатор);

	КонецЦикла;

	Если УникальныеСсылки.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Валидаторы.Ссылка КАК Ссылка,
	|	Валидаторы.КодВалидации КАК КодВалидации
	|ИЗ
	|	Справочник.КИИ_ВалидаторыОтветаИИ КАК Валидаторы
	|ГДЕ
	|	Валидаторы.Ссылка В (&Валидаторы)";

	Запрос.УстановитьПараметр("Валидаторы", УникальныеСсылки);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Ссылка, Выборка.КодВалидации);
	КонецЦикла;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция МассивВалидаторов(Валидатор)

	Результат = Новый Массив;
	Результат.Добавить(Валидатор);

	Возврат Результат;

КонецФункции

#КонецОбласти

#КонецЕсли
