
#Область ПрограммныйИнтерфейс

// Настраивает колонку признака ручной проверки ИИ в журнале «Банковские выписки».
//
// Параметры:
//  ДинамическийСписок - ДинамическийСписок - реквизит формы «Список»
//  ЭлементыФормы - ВсеЭлементыФормы - элементы управляемой формы
//
Процедура НастроитьПризнакРучнойПроверкиИИ(ДинамическийСписок, ЭлементыФормы) Экспорт

	ДобавитьПолеПризнакаИИВДинамическийСписок(ДинамическийСписок);
	ДобавитьКолонкуПризнакаИИ(ЭлементыФормы);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьПолеПризнакаИИВДинамическийСписок(ДинамическийСписок)

	Если ДинамическийСписок = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ИмяПоля = "kh_ТребуетсяРучнаяПроверкаИИ";

	Если ПолеПризнакаИИУжеДобавлено(ДинамическийСписок, ИмяПоля) Тогда
		Возврат;
	КонецЕсли;

	ТекстЗапроса = ДинамическийСписок.ТекстЗапроса;

	// Ищем позицию начала строки "ИЗ" — секция FROM
	МаркерИЗ = Символы.ПС + "ИЗ";
	ПозицияИЗ = СтрНайти(ТекстЗапроса, МаркерИЗ);

	Если ПозицияИЗ = 0 Тогда
		Возврат;
	КонецЕсли;

	ВыражениеПоля = ТекстВыраженияПоляПризнакаИИ();
	НовоеПоле = "," + Символы.ПС + Символы.Таб + ВыражениеПоля + " КАК " + ИмяПоля;

	ДинамическийСписок.ТекстЗапроса =
		Лев(ТекстЗапроса, ПозицияИЗ - 1)
		+ НовоеПоле
		+ Сред(ТекстЗапроса, ПозицияИЗ);

КонецПроцедуры

Функция ПолеПризнакаИИУжеДобавлено(ДинамическийСписок, ИмяПоля)

	// Проверяем по тексту запроса — это надёжнее обхода ВыбираемыхПолей схемы,
	// где могут встречаться объекты без свойства Псевдоним (например, звёздочка).
	Возврат СтрНайти(ДинамическийСписок.ТекстЗапроса, "КАК " + ИмяПоля) > 0;

КонецФункции

Функция ТекстВыраженияПоляПризнакаИИ()

	Возврат
		"ВЫБОР
		|	КОГДА ЖурналДокументовБанковскиеВыписки.Ссылка ССЫЛКА Документ.ПоступлениеНаРасчетныйСчет
		|		ТОГДА ЕСТЬNULL(
		|			ВЫРАЗИТЬ(ЖурналДокументовБанковскиеВыписки.Ссылка КАК Документ.ПоступлениеНаРасчетныйСчет).kh_ТребуетсяРучнаяПроверкаИИ,
		|			ЛОЖЬ)
		|	ИНАЧЕ ЛОЖЬ
		|КОНЕЦ";

КонецФункции

Процедура ДобавитьКолонкуПризнакаИИ(ЭлементыФормы)

	ИмяКолонки = "kh_ТребуетсяРучнаяПроверкаИИ";

	Если ЭлементыФормы.Найти(ИмяКолонки) <> Неопределено Тогда
		Возврат;
	КонецЕсли;

	Колонка = ЭлементыФормы.Добавить(ИмяКолонки, Тип("ПолеФормы"), ЭлементыФормы.Список);
	Колонка.Вид = ВидПоляФормы.ПолеФлажка;
	Колонка.ПутьКДанным = "Список." + ИмяКолонки;
	Колонка.Заголовок = НСтр("ru = 'Требуется проверка'");
	Колонка.ТолькоПросмотр = Истина;
	Колонка.Подсказка = НСтр("ru = 'Требуется ручная проверка результата AI-анализа назначения платежа'");

КонецПроцедуры

#КонецОбласти
