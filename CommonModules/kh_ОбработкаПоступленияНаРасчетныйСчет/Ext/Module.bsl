
#Область ПрограммныйИнтерфейс

// Ключ дополнительного свойства: пропустить любой AI-анализ для данной записи документа.
//
// Возвращаемое значение:
//  Строка
//
Функция КлючПропуститьАнализИИ() Экспорт

	Возврат "kh_ПропуститьАнализИИ";

КонецФункции

// Устанавливает на документе признак пропуска AI-аниза (массовая загрузка тестовых данных).
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//
Процедура УстановитьПропускАнализаИИ(ДокументОбъект) Экспорт

	ДокументОбъект.ДополнительныеСвойства.Вставить(КлючПропуститьАнализИИ(), Истина);

КонецПроцедуры

// Обработчик расширения перед записью: планирует отложенный анализ для новых документов.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//  Отказ - Булево
//  РежимЗаписи - РежимЗаписиДокумента
//  РежимПроведения - РежимПроведенияДокумента
//
Процедура ПередЗаписьюАнализНазначенияПлатежа(ДокументОбъект, Отказ, РежимЗаписи, РежимПроведения) Экспорт

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Если ПропуститьАнализИИ(ДокументОбъект) Тогда
		Возврат;
	КонецЕсли;

	Если ВыполняетсяЗагрузкаДанных(ДокументОбъект) Тогда
		Возврат;
	КонецЕсли;

	Если ЗаписьРезультатаАнализаИИ(ДокументОбъект) Тогда
		ДокументОбъект.ДополнительныеСвойства.Удалить(КлючЗаписьРезультатаАнализаИИ());
		Возврат;
	КонецЕсли;

	Если Не ТребуетсяАвтоанализПриЗаписи(ДокументОбъект) Тогда
		Возврат;
	КонецЕсли;

	ДокументОбъект.ДополнительныеСвойства.Вставить(КлючЗапланироватьАнализПослеЗаписи(), Истина);
	ДокументОбъект.ДополнительныеСвойства.Вставить(КлючРежимЗаписиПослеАнализа(), РежимЗаписи);

КонецПроцедуры

// Обработчик расширения после записи: выполняет отложенный AI-анализ и сохраняет результат.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//  Отказ - Булево
//
Процедура ПослеЗаписиАнализНазначенияПлатежа(ДокументОбъект, Отказ) Экспорт

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Если ПропуститьАнализИИ(ДокументОбъект) Тогда
		Возврат;
	КонецЕсли;

	Если ВыполняетсяЗагрузкаДанных(ДокументОбъект) Тогда
		Возврат;
	КонецЕсли;

	Если Не ЗапланированАнализПослеЗаписи(ДокументОбъект) Тогда
		Возврат;
	КонецЕсли;

	ДокументОбъект.ДополнительныеСвойства.Удалить(КлючЗапланироватьАнализПослеЗаписи());

	РежимЗаписи = РежимЗаписиДокумента.Запись;

	Если ДокументОбъект.ДополнительныеСвойства.Свойство(КлючРежимЗаписиПослеАнализа()) Тогда
		РежимЗаписи = ДокументОбъект.ДополнительныеСвойства[КлючРежимЗаписиПослеАнализа()];
		ДокументОбъект.ДополнительныеСвойства.Удалить(КлючРежимЗаписиПослеАнализа());
	КонецЕсли;

	ВыполнитьАнализИЗаполнение(ДокументОбъект, Ложь);

	ДокументОбъект.ДополнительныеСвойства.Вставить(КлючЗаписьРезультатаАнализаИИ(), Истина);
	ДокументОбъект.Записать(РежимЗаписи);

КонецПроцедуры

// Выполняет анализ назначения платежа и заполняет расшифровку по результату.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//  Принудительно - Булево - Истина для ручного перезапуска с формы
//
Процедура ВыполнитьАнализИЗаполнение(ДокументОбъект, Принудительно = Ложь) Экспорт

	Если Не МожноЗапускатьАнализ(ДокументОбъект, Принудительно) Тогда
		Возврат;
	КонецЕсли;

	РезультатАнализа = kh_АнализНазначенияПлатежа.ВыполнитьАнализ(
		ДокументОбъект.НазначениеПлатежа,
		ДокументОбъект.Контрагент,
		ДокументОбъект.СуммаДокумента,
		ДокументОбъект.Ссылка);

	Если РезультатАнализа.ЭтоОшибкаAPI Тогда
		ДокументОбъект.kh_ТребуетсяРучнаяПроверкаИИ = Истина;
		СообщитьПользователюОРезультатеАнализа(РезультатАнализа.ТекстОшибкиAPI, ДокументОбъект);
		Возврат;
	КонецЕсли;

	Если Принудительно Тогда
		ДокументОбъект.РасшифровкаПлатежа.Очистить();
	КонецЕсли;

	ЗаполнитьРасшифровкуПлатежа(ДокументОбъект, РезультатАнализа);
	ДокументОбъект.kh_ТребуетсяРучнаяПроверкаИИ = РезультатАнализа.НужнаРучнаяПроверка;

	Если Не ПустаяСтрока(РезультатАнализа.Сообщение) Тогда
		СообщитьПользователюОРезультатеАнализа(РезультатАнализа.Сообщение, ДокументОбъект);
	КонецЕсли;

КонецПроцедуры

// Сохраняет документ после ручного AI-аниза с формы (без повторного автозапуска).
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//
Процедура ЗаписатьДокументПослеРучногоАнализа(ДокументОбъект) Экспорт

	ДокументОбъект.ДополнительныеСвойства.Вставить(КлючЗаписьРезультатаАнализаИИ(), Истина);
	ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция КлючЗапланироватьАнализПослеЗаписи()

	Возврат "kh_ЗапланироватьАнализПослеЗаписи";

КонецФункции

Функция КлючЗаписьРезультатаАнализаИИ()

	Возврат "kh_ЗаписьРезультатаАнализаИИ";

КонецФункции

Функция КлючРежимЗаписиПослеАнализа()

	Возврат "kh_РежимЗаписиПослеАнализа";

КонецФункции

Функция ПропуститьАнализИИ(ДокументОбъект)

	Ключ = КлючПропуститьАнализИИ();

	Если Не ДокументОбъект.ДополнительныеСвойства.Свойство(Ключ) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат ДокументОбъект.ДополнительныеСвойства[Ключ] = Истина;

КонецФункции

Функция ЗапланированАнализПослеЗаписи(ДокументОбъект)

	Ключ = КлючЗапланироватьАнализПослеЗаписи();

	Если Не ДокументОбъект.ДополнительныеСвойства.Свойство(Ключ) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат ДокументОбъект.ДополнительныеСвойства[Ключ] = Истина;

КонецФункции

Функция ЗаписьРезультатаАнализаИИ(ДокументОбъект)

	Ключ = КлючЗаписьРезультатаАнализаИИ();

	Если Не ДокументОбъект.ДополнительныеСвойства.Свойство(Ключ) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат ДокументОбъект.ДополнительныеСвойства[Ключ] = Истина;

КонецФункции

Функция ТребуетсяАвтоанализПриЗаписи(ДокументОбъект)

	Если Не ДокументОбъект.ЭтоНовый() Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат МожноЗапускатьАнализ(ДокументОбъект, Ложь);

КонецФункции

Функция МожноЗапускатьАнализ(ДокументОбъект, Принудительно)

	Если Не ЗначениеЗаполнено(ДокументОбъект.Контрагент) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если ПустаяСтрока(ДокументОбъект.НазначениеПлатежа) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если ВыполняетсяЗагрузкаДанных(ДокументОбъект) Тогда
		Возврат Ложь;
	КонецЕсли;

	// AI-анализ применяется только к поступлениям с видом операции «Оплата от покупателя».
	// Ограничение действует и при ручном запуске с формы.
	Если ДокументОбъект.ВидОперации <> Перечисления.ВидыОперацийПоступлениеДенежныхСредств.ОплатаПокупателя Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Принудительно Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат ДоговорНеЗаполненВРасшифровкеПлатежа(ДокументОбъект);

КонецФункции

// Истина, если расшифровка пуста или ни в одной строке не указан договор контрагента.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//
// Возвращаемое значение:
//  Булево
//
Функция ДоговорНеЗаполненВРасшифровкеПлатежа(ДокументОбъект)

	Если ДокументОбъект.РасшифровкаПлатежа.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;

	Для Каждого СтрокаРасшифровки Из ДокументОбъект.РасшифровкаПлатежа Цикл

		Если ЗначениеЗаполнено(СтрокаРасшифровки.ДоговорКонтрагента) Тогда
			Возврат Ложь;
		КонецЕсли;

	КонецЦикла;

	Возврат Истина;

КонецФункции

Процедура ЗаполнитьРасшифровкуПлатежа(ДокументОбъект, РезультатАнализа)

	Если Не РезультатАнализа.МожноАвтозаполнять Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Кандидат Из РезультатАнализа.ПодтвержденныеКандидаты Цикл

		Если Не ЗначениеЗаполнено(Кандидат.Договор) Тогда
			Продолжить;
		КонецЕсли;

		СтрокаРасшифровки = СтрокаРасшифровкиДляЗаполнения(ДокументОбъект);
		СтрокаРасшифровки.ДоговорКонтрагента = Кандидат.Договор;
		СтрокаРасшифровки.СуммаПлатежа = Кандидат.Сумма;

		ДозаполнитьСтрокуТиповымиСвойствамиПлатежа(ДокументОбъект, СтрокаРасшифровки);

	КонецЦикла;

КонецПроцедуры

// Дозаполняет строку расшифровки платежа недостающими реквизитами через типовой механизм
// ПоступлениеНаРасчетныйСчетФормы.СвойстваСтрокРасшифровкиПлатежаСервер.
//
// Контракт:
//  - ДоговорКонтрагента и СуммаПлатежа строки НЕ перезаписываются (уже проставлены ИИ).
//  - СуммаДокумента шапки НЕ пересчитывается (контрольное значение сверки с выпиской).
//  - Уже заполненные поля строки сохраняются.
//
// Параметры:
//  ДокументОбъект    - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//  СтрокаРасшифровки - СтрокаТабличнойЧасти.РасшифровкаПлатежа
//
Процедура ДозаполнитьСтрокуТиповымиСвойствамиПлатежа(ДокументОбъект, СтрокаРасшифровки)

	ПараметрыПлатежа = ПараметрыПлатежаДляСтрокиРасшифровки(ДокументОбъект, СтрокаРасшифровки);
	СвойстваПлатежа = ПоступлениеНаРасчетныйСчетФормы.СвойстваСтрокРасшифровкиПлатежаСервер(ПараметрыПлатежа, Ложь);
	ДополнитьСвойстваПлатежаАналитикой(СвойстваПлатежа, ДокументОбъект);

	ПрименитьСвойстваПлатежаКСтроке(СтрокаРасшифровки, СвойстваПлатежа);

КонецПроцедуры

// Формирует структуру ПараметрыПлатежа из шапки документа и строки расшифровки
// для передачи в типовой ПоступлениеНаРасчетныйСчетФормы.СвойстваСтрокРасшифровкиПлатежаСервер.
//
// Параметры:
//  ДокументОбъект    - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//  СтрокаРасшифровки - СтрокаТабличнойЧасти.РасшифровкаПлатежа
//
// Возвращаемое значение:
//  Структура - поля ПараметрыПлатежа, ожидаемые типовой функцией
//
Функция ПараметрыПлатежаДляСтрокиРасшифровки(ДокументОбъект, СтрокаРасшифровки)

	// Полный набор ключей — как в ПоступлениеНаРасчетныйСчетФормыКлиентСервер.СвойстваСтрокРасшифровкиПлатежа;
	// типовая СвойстваСтрокРасшифровкиПлатежаСервер обращается к полям через точку (без Свойство()).
	ПараметрыПлатежа = Новый Структура(
		"ВидОперации, Организация, Дата, Контрагент, ДоговорКонтрагента,
		|ПрименениеУСН, ПрименяетсяОсобыйПорядокНалогообложения, ПлательщикНДС, ПлательщикНПД, УслугаНПД,
		|ОтражатьРазницуВКурсеВСоставеОперационныхРасходов, СуммаДокумента, СуммаПлатежа, ВидОплаты,
		|ВидОплатыРеквизиты, СуммаУслуг, СуммаВозврата, СтатьяДвиженияДенежныхСредств, ПлательщикНДСПриУСН,
		|НазначениеПлатежа, СтавкаНДСПриУСН, ПорядокОтраженияАванса, Ссылка");

	ЗаполнитьЗначенияСвойств(ПараметрыПлатежа, ДокументОбъект);
	ЗаполнитьЗначенияСвойств(ПараметрыПлатежа, СтрокаРасшифровки,
		"ДоговорКонтрагента, СуммаПлатежа, СтатьяДвиженияДенежныхСредств, ПорядокОтраженияАванса,
		|УслугаНПД, СуммаУслуг, СуммаВозврата");

	ВалютаРегламентированногоУчета = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	ПараметрыПлатежа.Вставить("ВалютаРегламентированногоУчета", ВалютаРегламентированногоУчета);

	Если ДокументОбъект.ВалютаДокумента = ВалютаРегламентированногоУчета Тогда
		ПараметрыПлатежа.Вставить("ОплатаВВалюте",   Ложь);
		ПараметрыПлатежа.Вставить("ВалютаДокумента", ВалютаРегламентированногоУчета);
	Иначе
		ПараметрыПлатежа.Вставить("ОплатаВВалюте",   Истина);
		ПараметрыПлатежа.Вставить("ВалютаДокумента", ДокументОбъект.ВалютаДокумента);
	КонецЕсли;

	ЗаполнитьНалоговыеПараметрыПлатежа(ПараметрыПлатежа, ДокументОбъект.Организация, ДокументОбъект.Дата);

	Возврат ПараметрыПлатежа;

КонецФункции

// Дополняет ПараметрыПлатежа налоговыми признаками организации (без формы).
// Эталон: МенеджерОбменаЧерезУниверсальныйФормат13.ОтложеннаяОбработка_ПоступлениеНаРС_Расчеты.
//
Процедура ЗаполнитьНалоговыеПараметрыПлатежа(ПараметрыПлатежа, Организация, Дата)

	ПараметрыПлатежа.ПрименениеУСН =
		УчетнаяПолитика.ПрименяетсяУСН(Организация, Дата);
	ПараметрыПлатежа.ПрименяетсяОсобыйПорядокНалогообложения =
		УчетнаяПолитика.ПрименяетсяОсобыйПорядокНалогообложения(Организация, Дата);
	ПараметрыПлатежа.ПлательщикНПД =
		УчетнаяПолитика.ПрименяетсяУСНПатент(Организация, Дата);

	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(Организация, Дата);
	ПараметрыПлатежа.ПлательщикНДС = ПлательщикНДС;

	ПлательщикНДСПриУСН = УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(Организация, Дата);
	ПараметрыПлатежа.ПлательщикНДСПриУСН = ПлательщикНДСПриУСН;

	СтавкаНДСПриУСН = Перечисления.СтавкиНДС.ПустаяСсылка();
	Если ПлательщикНДСПриУСН Тогда
		СтавкаНалогообложенияПриУСН = РегистрыСведений.НастройкиУчетаНДС.СтавкаНалогообложенияПриУСН(Организация, Дата);
		Если СтавкаНалогообложенияПриУСН = Перечисления.ВидыСтавокНДС.Общая Тогда
			СтавкаНДСПриУСН = УчетНДСКлиентСервер.СтавкаНДСПользователя(Дата, Истина);
		Иначе
			СтавкаНДСПриУСН = Перечисления.СтавкиНДС.СтавкаНДС(СтавкаНалогообложенияПриУСН, Дата);
		КонецЕсли;
	КонецЕсли;
	ПараметрыПлатежа.СтавкаНДСПриУСН = СтавкаНДСПриУСН;

КонецПроцедуры

// Дополняет свойства платежа счетами расчетов и статьей ДДС.
//
// Параметры:
//  СвойстваПлатежа - Структура - свойства строки расшифровки платежа
//  ДокументОбъект  - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//
Процедура ДополнитьСвойстваПлатежаАналитикой(СвойстваПлатежа, ДокументОбъект)

	АналитикаПоШаблону = АналитикаПлатежаПоШаблонамАналитикПлатежей(ДокументОбъект);

	Если ЗначениеЗаполнено(АналитикаПоШаблону.СчетУчетаРасчетовСКонтрагентом) Тогда
		СвойстваПлатежа.СчетУчетаРасчетовСКонтрагентом = АналитикаПоШаблону.СчетУчетаРасчетовСКонтрагентом;
	КонецЕсли;

	Если ЗначениеЗаполнено(АналитикаПоШаблону.СчетУчетаРасчетовПоАвансам) Тогда
		СвойстваПлатежа.СчетУчетаРасчетовПоАвансам = АналитикаПоШаблону.СчетУчетаРасчетовПоАвансам;
	КонецЕсли;

	ЗаполнитьСтатьюДДСПоДоговоруИШаблону(СвойстваПлатежа, АналитикаПоШаблону);

КонецПроцедуры

// Заполняет статью ДДС по приоритету: договор, шаблон аналитик, типовое значение по умолчанию.
//
// Параметры:
//  СвойстваПлатежа    - Структура - свойства строки расшифровки платежа
//  АналитикаПоШаблону - Структура - аналитики из регистра ШаблоныАналитикПлатежей
//
Процедура ЗаполнитьСтатьюДДСПоДоговоруИШаблону(СвойстваПлатежа, АналитикаПоШаблону)

	СтатьяДДС = Неопределено;

	Если ЗначениеЗаполнено(СвойстваПлатежа.ДоговорКонтрагента) Тогда
		СтатьяДДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			СвойстваПлатежа.ДоговорКонтрагента,
			"СтатьяДвиженияДенежныхСредств");
	КонецЕсли;

	Если Не ЗначениеЗаполнено(СтатьяДДС)
		И ЗначениеЗаполнено(АналитикаПоШаблону.СтатьяДвиженияДенежныхСредств) Тогда

		СтатьяДДС = АналитикаПоШаблону.СтатьяДвиженияДенежныхСредств;
	КонецЕсли;

	Если ЗначениеЗаполнено(СтатьяДДС) Тогда
		СвойстваПлатежа.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
	КонецЕсли;

КонецПроцедуры

// Подбирает аналитику платежа по наиболее точному шаблону аналитик платежей.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//
// Возвращаемое значение:
//  Структура - СчетУчетаРасчетовСКонтрагентом, СчетУчетаРасчетовПоАвансам, СтатьяДвиженияДенежныхСредств
//
Функция АналитикаПлатежаПоШаблонамАналитикПлатежей(ДокументОбъект)

	Результат = Новый Структура(
		"СчетУчетаРасчетовСКонтрагентом, СчетУчетаРасчетовПоАвансам, СтатьяДвиженияДенежныхСредств");

	ДеревоДокументов = ДеревоДокументовДляПодбораШаблонаАналитик(ДокументОбъект);
	АдресХранилища = ПоместитьВоВременноеХранилище(ДеревоДокументов);
	ПараметрыЗаполнения = Новый Структура("ДеревоДокументов", ДеревоДокументов);

	Обработки.РазнесениеВыписки.ЗаполнитьПоШаблонамАналитик(ПараметрыЗаполнения, АдресХранилища);

	ДеревоДокументов = ПолучитьИзВременногоХранилища(АдресХранилища);
	Если ДеревоДокументов.Строки.Количество() > 0 Тогда
		ЗаполнитьЗначенияСвойств(Результат, ДеревоДокументов.Строки[0]);
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Формирует минимальное дерево, ожидаемое обработкой РазнесениеВыписки.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//
// Возвращаемое значение:
//  ДеревоЗначений
//
Функция ДеревоДокументовДляПодбораШаблонаАналитик(ДокументОбъект)

	ДеревоДокументов = Новый ДеревоЗначений;

	МетаданныеДокумента = Метаданные.Документы.ПоступлениеНаРасчетныйСчет;
	ДеревоДокументов.Колонки.Добавить("Ссылка",
		Новый ОписаниеТипов("ДокументСсылка.ПоступлениеНаРасчетныйСчет, ДокументСсылка.СписаниеСРасчетногоСчета"));
	ДеревоДокументов.Колонки.Добавить("Организация", МетаданныеДокумента.Реквизиты.Организация.Тип);
	ДеревоДокументов.Колонки.Добавить("Контрагент", МетаданныеДокумента.Реквизиты.Контрагент.Тип);
	ДеревоДокументов.Колонки.Добавить("СчетОрганизации", МетаданныеДокумента.Реквизиты.СчетОрганизации.Тип);
	ДеревоДокументов.Колонки.Добавить("НазначениеПлатежа", МетаданныеДокумента.Реквизиты.НазначениеПлатежа.Тип);

	Для Каждого Ресурс Из Метаданные.РегистрыСведений.ШаблоныАналитикПлатежей.Ресурсы Цикл
		ДеревоДокументов.Колонки.Добавить(Ресурс.Имя, Ресурс.Тип);
	КонецЦикла;

	ДеревоДокументов.Колонки.Добавить("РезультатЗаполненияАналитик", Новый ОписаниеТипов("Строка"));
	ДеревоДокументов.Колонки.Добавить("ДанныеИзменены", Новый ОписаниеТипов("Булево"));

	СтрокаДерева = ДеревоДокументов.Строки.Добавить();
	СтрокаДерева.Ссылка = ДокументОбъект.Ссылка;
	СтрокаДерева.Организация = ДокументОбъект.Организация;
	СтрокаДерева.Контрагент = ДокументОбъект.Контрагент;
	СтрокаДерева.СчетОрганизации = ДокументОбъект.СчетОрганизации;
	СтрокаДерева.НазначениеПлатежа = ДокументОбъект.НазначениеПлатежа;
	СтрокаДерева.РезультатЗаполненияАналитик = "";
	СтрокаДерева.ДанныеИзменены = Ложь;

	Возврат ДеревоДокументов;

КонецФункции

// Копирует в строку расшифровки только заполненные значения СвойстваПлатежа,
// не затирая ДоговорКонтрагента, СуммаПлатежа и уже заполненные поля строки.
//
Процедура ПрименитьСвойстваПлатежаКСтроке(СтрокаРасшифровки, СвойстваПлатежа)

	ЗащищенныеПоля = Новый Соответствие;
	ЗащищенныеПоля.Вставить("ДоговорКонтрагента", Истина);
	ЗащищенныеПоля.Вставить("СуммаПлатежа", Истина);
	ЗащищенныеПоля.Вставить("СуммаДокумента", Истина);

	Для Каждого Элемент Из СвойстваПлатежа Цикл

		Если ЗащищенныеПоля.Получить(Элемент.Ключ) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Если Не ЗначениеЗаполнено(Элемент.Значение) Тогда
			Продолжить;
		КонецЕсли;

		ИмяПоляСтроки = Элемент.Ключ;
		Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаРасшифровки, ИмяПоляСтроки) Тогда
			Продолжить;
		КонецЕсли;

		Если ЗначениеЗаполнено(СтрокаРасшифровки[ИмяПоляСтроки]) Тогда
			Продолжить;
		КонецЕсли;

		СтрокаРасшифровки[ИмяПоляСтроки] = Элемент.Значение;

	КонецЦикла;

КонецПроцедуры

// Возвращает первую пустую строку расшифровки или добавляет новую.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект.ПоступлениеНаРасчетныйСчет
//
// Возвращаемое значение:
//  СтрокаТабличнойЧасти
//
Функция СтрокаРасшифровкиДляЗаполнения(ДокументОбъект)

	Для Каждого СтрокаРасшифровки Из ДокументОбъект.РасшифровкаПлатежа Цикл

		Если Не ЗначениеЗаполнено(СтрокаРасшифровки.ДоговорКонтрагента)
			И Не ЗначениеЗаполнено(СтрокаРасшифровки.СуммаПлатежа) Тогда

			Возврат СтрокаРасшифровки;

		КонецЕсли;

	КонецЦикла;

	Возврат ДокументОбъект.РасшифровкаПлатежа.Добавить();

КонецФункции

Процедура СообщитьПользователюОРезультатеАнализа(ТекстСообщения, ДокументОбъект)

	Если ПустаяСтрока(ТекстСообщения) Тогда
		Возврат;
	КонецЕсли;

	Если Не СледуетСообщатьПользователю(ДокументОбъект) Тогда
		Возврат;
	КонецЕсли;

	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);

КонецПроцедуры

Функция СледуетСообщатьПользователю(ДокументОбъект)

	Если ПропуститьАнализИИ(ДокументОбъект) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если ВыполняетсяЗагрузкаДанных(ДокументОбъект) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Истина;

КонецФункции

Функция ВыполняетсяЗагрузкаДанных(ДокументОбъект)

	Возврат ДокументОбъект.ОбменДанными.Загрузка;

КонецФункции

#КонецОбласти
