//
// Параметры:
//  СхемаОтвета - СправочникСсылка.КИИ_СхемыОтветаИИ
//
// Возвращаемое значение:
//  СправочникСсылка.КИИ_ВалидаторыОтветаИИ
//
Функция ВалидаторОтветаСхемы(СхемаОтвета) Экспорт

	Возврат Справочники.КИИ_СхемыОтветаИИ.ВалидаторОтвета(СхемаОтвета);

КонецФункции

// Возвращает доверенный код валидации всего ответа модели по схеме.
//
// Параметры:
//  СхемаОтвета - СправочникСсылка.КИИ_СхемыОтветаИИ
//
// Возвращаемое значение:
//  Строка
//
Функция КодВалидацииОтветаСхемы(СхемаОтвета) Экспорт

	Возврат Справочники.КИИ_СхемыОтветаИИ.КодВалидацииОтвета(СхемаОтвета);

КонецФункции

// Возвращает описания полей с доверенным кодом валидации.
// Код валидации не включается в JSON Schema для модели.
//
// Параметры:
//  СхемаОтвета - СправочникСсылка.КИИ_СхемыОтветаИИ
//
// Возвращаемое значение:
//  Массив из Структура - см. Справочники.КИИ_СхемыОтветаИИ.ПолучитьВалидаторыПолей
//
Функция ПолучитьВалидаторыПолейСхемы(СхемаОтвета) Экспорт

	Возврат Справочники.КИИ_СхемыОтветаИИ.ПолучитьВалидаторыПолей(СхемаОтвета);

КонецФункции

// Проверяет JSON-ответ модели по схеме и валидаторам 1С.
//
// Параметры:
//  Эксперт - СправочникСсылка.КИИ_ЭкспертыИИ
//  ТекстОтветаJSON - Строка
//  КонтекстПроверки - Структура - произвольный контекст для валидаторов (необязательно)
//  КоличествоВыполненныхПовторов - Число - сколько повторов уже выполнено до текущей попытки
//
// Возвращаемое значение:
//  Структура - см. КИИ_ВалидацияОтветаИИ.НовыйИтогВалидации
//
Функция ПроверитьОтветПоСхеме(Эксперт, ТекстОтветаJSON, КонтекстПроверки = Неопределено, КоличествоВыполненныхПовторов = 0) Экспорт

	СхемаОтвета = ПолучитьСхемуОтветаЭксперта(Эксперт);
	Модель = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Эксперт, "Модель");

	Если Не ЗначениеЗаполнено(СхемаОтвета) Тогда
		ВызватьИсключение НСтр("ru = 'У эксперта ИИ не указана схема ответа.'");
	КонецЕсли;

	Итог = КИИ_ВалидацияОтветаИИ.ПроверитьОтветПоСхеме(СхемаОтвета, Модель, ТекстОтветаJSON, КонтекстПроверки);
	ЛимитПовторов = ЛимитПовторныхЗапросовЭксперта(Эксперт);

	Возврат КИИ_ВалидацияОтветаИИ.ПрименитьЛимитПовторныхЗапросов(Итог, ЛимитПовторов, КоличествоВыполненныхПовторов);

КонецФункции

// Возвращает эксперта ИИ, сопоставленного с назначением в регистре сведений КИИ_НазначенияЭкспертов.
//
// Параметры:
//  Назначение - ПланВидовХарактеристикСсылка.КИИ_НазначенияЭкспертов
//
// Возвращаемое значение:
//  СправочникСсылка.КИИ_ЭкспертыИИ
//
Функция ЭкспертПоНазначению(Назначение) Экспорт

	Если Не ЗначениеЗаполнено(Назначение) Тогда
		Возврат Справочники.КИИ_ЭкспертыИИ.ПустаяСсылка();
	КонецЕсли;

	Отбор = Новый Структура("Назначение", Назначение);
	Запись = РегистрыСведений.КИИ_НазначенияЭкспертов.Получить(Отбор);

	Возврат Запись.Эксперт;

КонецФункции

// Проверяет, что для назначения настроен непустой эксперт ИИ.
//
// Параметры:
//  Назначение - ПланВидовХарактеристикСсылка.КИИ_НазначенияЭкспертов
//
// Возвращаемое значение:
//  Структура - Эксперт, ЭтоОшибка, ТекстОшибки
//
Функция ПроверитьНаличиеЭкспертаДляНазначения(Назначение) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Эксперт", Справочники.КИИ_ЭкспертыИИ.ПустаяСсылка());
	Результат.Вставить("ЭтоОшибка", Ложь);
	Результат.Вставить("ТекстОшибки", "");

	Если Не ЗначениеЗаполнено(Назначение) Тогда
		Результат.ЭтоОшибка = Истина;
		Результат.ТекстОшибки = НСтр("ru = 'Назначение эксперта ИИ не задано.'");
		Возврат Результат;
	КонецЕсли;

	Эксперт = ЭкспертПоНазначению(Назначение);

	Если Не ЗначениеЗаполнено(Эксперт) Тогда
		Результат.ЭтоОшибка = Истина;
		Результат.ТекстОшибки = СтрШаблон(
			НСтр("ru = 'Для назначения ""%1"" не настроен эксперт ИИ. Заполните запись в регистре сведений ""Эксперты ИИ по назначениям"".'"),
			Назначение);
		Возврат Результат;
	КонецЕсли;

	Результат.Эксперт = Эксперт;
	Возврат Результат;

КонецФункции

#КонецОбласти

