#Область ПрограммныйИнтерфейс

// Возвращает ссылку на схему ответа, привязанную к эксперту ИИ.
//
// Параметры:
//  Эксперт - СправочникСсылка.КИИ_ЭкспертыИИ
//
// Возвращаемое значение:
//  СправочникСсылка.КИИ_СхемыОтветаИИ
//
Функция ПолучитьСхемуОтветаЭксперта(Эксперт) Экспорт

	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Эксперт, "СхемаОтвета");

КонецФункции

// Возвращает лимит повторных запросов к модели для эксперта.
// При нулевом или незаполненном значении в метаданных используется значение по умолчанию 3.
//
// Параметры:
//  Эксперт - СправочникСсылка.КИИ_ЭкспертыИИ
//
// Возвращаемое значение:
//  Число
//
Функция ЛимитПовторныхЗапросовЭксперта(Эксперт) Экспорт

	Лимит = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Эксперт, "ЛимитПовторныхЗапросов");

	Если Не ЗначениеЗаполнено(Лимит) Или Лимит <= 0 Тогда
		Возврат 3;
	КонецЕсли;

	Возврат Лимит;

КонецФункции

// Возвращает минимально допустимую уверенность модели (confidence) для автозаполнения кандидата.
// При пустом или некорректном значении в метаданных используется значение по умолчанию 0,7.
//
// Параметры:
//  Эксперт - СправочникСсылка.КИИ_ЭкспертыИИ
//
// Возвращаемое значение:
//  Число - от 0 до 1
//
Функция ПорогУверенностиКандидата(Эксперт) Экспорт

	Порог = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Эксперт, "ПорогУверенностиКандидата");

	Если Не ЗначениеЗаполнено(Порог) Или Порог <= 0 Или Порог > 1 Тогда
		Возврат ПорогУверенностиКандидатаПоУмолчанию();
	КонецЕсли;

	Возврат Порог;

КонецФункции

// Формирует JSON Schema по данным метаданных схемы ответа.
//
// Параметры:
//  СхемаОтвета - СправочникСсылка.КИИ_СхемыОтветаИИ
//
// Возвращаемое значение:
//  Структура - JSON Schema корневого объекта
//
Функция СформироватьJsonSchema(СхемаОтвета) Экспорт

	Возврат Справочники.КИИ_СхемыОтветаИИ.СформироватьJsonSchema(СхемаОтвета);

КонецФункции

// Формирует структуру response_format для AI Studio (json_schema).
//
// Параметры:
//  СхемаОтвета - СправочникСсылка.КИИ_СхемыОтветаИИ
//
// Возвращаемое значение:
//  Структура - response_format с полями type, json_schema
//
Функция СформироватьResponseFormat(СхемаОтвета) Экспорт

	Возврат Справочники.КИИ_СхемыОтветаИИ.СформироватьResponseFormat(СхемаОтвета);

КонецФункции

// Возвращает текст блока «Формат ответа (строго)» с JSON Schema для добавления в промпт.
// Если у эксперта не указана схема ответа — пустая строка.
//
// Параметры:
//  Эксперт - СправочникСсылка.КИИ_ЭкспертыИИ
//
// Возвращаемое значение:
//  Строка
//
Функция ТекстФорматаОтветаДляПромпта(Эксперт) Экспорт

	СхемаОтвета = ПолучитьСхемуОтветаЭксперта(Эксперт);

	Если Не ЗначениеЗаполнено(СхемаОтвета) Тогда
		Возврат "";
	КонецЕсли;

	JsonSchema = СформироватьJsonSchema(СхемаОтвета);
	ТекстСхемы = ОбщегоНазначения.ЗначениеВJSON(JsonSchema);

	Возврат НСтр("ru = 'Формат ответа (строго):'") + Символы.ПС + ТекстСхемы;

КонецФункции

