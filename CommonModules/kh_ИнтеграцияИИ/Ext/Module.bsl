
#Область ПрограммныйИнтерфейс

// Возвращает ссылку на эксперт анализа назначения платежа.
//
// Возвращаемое значение:
//  СправочникСсылка.КИИ_ЭкспертыИИ
//
Функция ЭкспертАнализаНазначенияПлатежа() Экспорт

	Возврат МодульЭкспертыИИ().ЭкспертПоНазначению(НазначениеАнализаНазначенияПлатежа());

КонецФункции

// Выполняет запрос к модели YandexGPT через модули коннектора КИИ_*.
//
// Параметры:
//  ПользовательскийПромпт - Строка - текст запроса (назначение платежа и контекст)
//  Документ - ДокументСсылка.ПоступлениеНаРасчетныйСчет, Неопределено - документ-инициатор запроса для лога
//  НомерПовтора - Число - порядковый номер запроса к модели в рамках одной попытки анализа
//
// Возвращаемое значение:
//  Структура - см. КИИ_КоннекторИИ.ЗапросКМодели
//
Функция ВыполнитьЗапросКМодели(ПользовательскийПромпт, Документ = Неопределено, НомерПовтора = 1) Экспорт

	ПроверкаЭксперта = МодульЭкспертыИИ().ПроверитьНаличиеЭкспертаДляНазначения(НазначениеАнализаНазначенияПлатежа());

	Если ПроверкаЭксперта.ЭтоОшибка Тогда
		Возврат НовыйРезультатОшибкиAPI(ПроверкаЭксперта.ТекстОшибки);
	КонецЕсли;

	Эксперт = ПроверкаЭксперта.Эксперт;
	РеквизитыЭксперта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		Эксперт,
		"Модель, СхемаОтвета, ОписаниеЭксперта");
	Модель = РеквизитыЭксперта.Модель;

	Если Не ЗначениеЗаполнено(Модель) Тогда
		Возврат НовыйРезультатОшибкиAPI(
			НСтр("ru = 'У эксперта анализа назначения платежа не указана модель ИИ.'"));
	КонецЕсли;

	Если Не ЗначениеЗаполнено(РеквизитыЭксперта.СхемаОтвета) Тогда
		Возврат НовыйРезультатОшибкиAPI(
			НСтр("ru = 'У эксперта анализа назначения платежа не указана схема ответа.'"));
	КонецЕсли;

	СтруктураПромпта = СформироватьСтруктуруПромпта(Эксперт, ПользовательскийПромпт, РеквизитыЭксперта);

	Возврат МодульКоннекторИИ().ЗапросКМодели(Модель, СтруктураПромпта, Документ, НомерПовтора);

КонецФункции

// Проверяет JSON-ответ модели по схеме эксперта через модули коннектора КИИ_*.
//
// Параметры:
//  ТекстОтветаJSON - Строка
//  КонтекстПроверки - Структура - контекст для валидаторов (Контрагент, СуммаПлатежа)
//  КоличествоВыполненныхПовторов - Число - число повторов до текущей попытки
//
// Возвращаемое значение:
//  Структура - см. КИИ_ВалидацияОтветаИИ.НовыйИтогВалидации
//
Функция ПроверитьОтветПоСхеме(ТекстОтветаJSON, КонтекстПроверки, КоличествоВыполненныхПовторов = 0) Экспорт

	ПроверкаЭксперта = МодульЭкспертыИИ().ПроверитьНаличиеЭкспертаДляНазначения(НазначениеАнализаНазначенияПлатежа());

	Если ПроверкаЭксперта.ЭтоОшибка Тогда
		ВызватьИсключение ПроверкаЭксперта.ТекстОшибки;
	КонецЕсли;

	Возврат МодульЭкспертыИИ().ПроверитьОтветПоСхеме(
		ПроверкаЭксперта.Эксперт,
		ТекстОтветаJSON,
		КонтекстПроверки,
		КоличествоВыполненныхПовторов);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НазначениеАнализаНазначенияПлатежа()

	Возврат ПланыВидовХарактеристик.КИИ_НазначенияЭкспертов.kh_АнализНазначенияПлатежаПоступленияНаРС;

КонецФункции

Функция СформироватьСтруктуруПромпта(Эксперт, ПользовательскийПромпт, РеквизитыЭксперта = Неопределено)

	Результат = Новый Структура;
	Результат.Вставить("СистемныйПромпт", "");
	Результат.Вставить("ПользовательскийПромпт", ПользовательскийПромпт);
	Результат.Вставить("ИсторияСообщений", Новый Массив);

	Если РеквизитыЭксперта = Неопределено Тогда
		РеквизитыЭксперта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			Эксперт,
			"ОписаниеЭксперта");
	КонецЕсли;

	ПромптЭксперта = РеквизитыЭксперта.ОписаниеЭксперта;
	ТекстФормата = МодульЭкспертыИИ().ТекстФорматаОтветаДляПромпта(Эксперт);

	Если Не ПустаяСтрока(ТекстФормата) Тогда

		Если Не ПустаяСтрока(ПромптЭксперта) Тогда
			Результат.СистемныйПромпт = ПромптЭксперта + Символы.ПС + Символы.ПС + ТекстФормата;
		Иначе
			Результат.СистемныйПромпт = ТекстФормата;
		КонецЕсли;

	Иначе
		Результат.СистемныйПромпт = ПромптЭксперта;
	КонецЕсли;

	Возврат Результат;

КонецФункции

Функция МодульЭкспертыИИ()

	Возврат КИИ_ЭкспертыИИ;

КонецФункции

Функция МодульКоннекторИИ()

	Возврат КИИ_КоннекторИИ;

КонецФункции

Функция НовыйРезультатОшибкиAPI(ТекстОшибки)

	Результат = Новый Структура;
	Результат.Вставить("ЭтоОшибка", Истина);
	Результат.Вставить("ТекстОшибки", ТекстОшибки);
	Результат.Вставить("ТекстОтвета", "");

	Возврат Результат;

КонецФункции

#КонецОбласти
