
#Область ПрограммныйИнтерфейс

// Возвращает пустую структуру результата анализа назначения платежа.
//
// Возвращаемое значение:
//  Структура:
//   * ЭтоОшибкаAPI - Булево
//   * ТекстОшибкиAPI - Строка
//   * ИтогВалидации - Структура, Неопределено - см. КИИ_ВалидацияОтветаИИ.НовыйИтогВалидации
//   * ПодтвержденныеКандидаты - Массив из Структура - Договор, Сумма, Индекс
//   * СпорныеКандидаты - Массив из Структура - Индекс, Класс, Сообщение
//   * МодельЗапросилаРучнуюПроверку - Булево - needsManualReview из ответа модели
//   * НужнаРучнаяПроверка - Булево - агрегированный признак для документа
//   * ПовторитьЗапрос - Булево
//   * МожноАвтозаполнять - Булево - есть подтверждённые кандидаты и нет блокирующих ошибок
//   * Сообщение - Строка
//
Функция НовыйРезультатАнализа() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("ЭтоОшибкаAPI", Ложь);
	Результат.Вставить("ТекстОшибкиAPI", "");
	Результат.Вставить("ИтогВалидации", Неопределено);
	Результат.Вставить("ПодтвержденныеКандидаты", Новый Массив);
	Результат.Вставить("СпорныеКандидаты", Новый Массив);
	Результат.Вставить("МодельЗапросилаРучнуюПроверку", Ложь);
	Результат.Вставить("НужнаРучнаяПроверка", Ложь);
	Результат.Вставить("ПовторитьЗапрос", Ложь);
	Результат.Вставить("МожноАвтозаполнять", Ложь);
	Результат.Вставить("Сообщение", "");

	Возврат Результат;

КонецФункции

// Формирует контекст проверки ответа модели для валидаторов схемы.
//
// Параметры:
//  Контрагент - СправочникСсылка.Контрагенты
//  СуммаПлатежа - Число
//
// Возвращаемое значение:
//  Структура
//
Функция НовыйКонтекстПроверки(Контрагент, СуммаПлатежа) Экспорт

	Контекст = Новый Структура;
	Контекст.Вставить("Контрагент", Контрагент);
	Контекст.Вставить("СуммаПлатежа", СуммаПлатежа);

	Возврат Контекст;

КонецФункции

// Формирует пользовательский промпт для эксперта анализа назначения платежа.
//
// Параметры:
//  НазначениеПлатежа - Строка
//  Контрагент - СправочникСсылка.Контрагенты
//  СуммаПлатежа - Число
//
// Возвращаемое значение:
//  Строка
//
Функция СформироватьПользовательскийПромпт(НазначениеПлатежа, Контрагент, СуммаПлатежа) Экспорт

	ЧастиПромпта = Новый Массив;
	ЧастиПромпта.Добавить(НСтр("ru = 'Назначение платежа:'"));
	ЧастиПромпта.Добавить(НазначениеПлатежа);
	ЧастиПромпта.Добавить("");
	ЧастиПромпта.Добавить(СтрШаблон(НСтр("ru = 'Сумма платежа: %1'"), Формат(СуммаПлатежа, "ЧДЦ=2; ЧРД=.; ЧГ=")));
	ЧастиПромпта.Добавить("");
	ЧастиПромпта.Добавить(НСтр("ru = 'Договоры контрагента (поле contract — точное наименование из списка):'"));
	ЧастиПромпта.Добавить(ТекстСпискаДоговоровКонтрагента(Контрагент));

	Возврат СтрСоединить(ЧастиПромпта, Символы.ПС);

КонецФункции

// Выполняет полный цикл анализа назначения платежа через модули коннектора КИИ_*.
//
// Параметры:
//  НазначениеПлатежа - Строка
//  Контрагент - СправочникСсылка.Контрагенты
//  СуммаПлатежа - Число
//  Документ - ДокументСсылка.ПоступлениеНаРасчетныйСчет, Неопределено - документ-инициатор запроса для лога
//
// Возвращаемое значение:
//  Структура - см. НовыйРезультатАнализа
//
Функция ВыполнитьАнализ(НазначениеПлатежа, Контрагент, СуммаПлатежа, Документ = Неопределено) Экспорт

	КонтекстПроверки = НовыйКонтекстПроверки(Контрагент, СуммаПлатежа);
	Эксперт = kh_ИнтеграцияИИ.ЭкспертАнализаНазначенияПлатежа();
	ПорогУверенностиКандидата = КИИ_ЭкспертыИИ.ПорогУверенностиКандидата(Эксперт);
	КоличествоВыполненныхПовторов = 0;
	ПользовательскийПромпт = СформироватьПользовательскийПромпт(НазначениеПлатежа, Контрагент, СуммаПлатежа);
	ПоследнееСообщениеВалидации = "";

	Пока Истина Цикл

		Если КоличествоВыполненныхПовторов >= МаксимальноеКоличествоПовторовАнализа() Тогда
			Возврат РезультатИсчерпаныПовторы(ПоследнееСообщениеВалидации);
		КонецЕсли;

		ТекстЗапроса = ПользовательскийПромпт;

		Если КоличествоВыполненныхПовторов > 0 И Не ПустаяСтрока(ПоследнееСообщениеВалидации) Тогда
			ТекстЗапроса = ТекстЗапроса + Символы.ПС + Символы.ПС
				+ СтрШаблон(
					НСтр("ru = 'Предыдущий ответ не прошёл валидацию: %1. Исправьте JSON-ответ согласно схеме.'"),
					ПоследнееСообщениеВалидации);
		КонецЕсли;

		НомерПовтора = КоличествоВыполненныхПовторов + 1;
		ОтветAPI = kh_ИнтеграцияИИ.ВыполнитьЗапросКМодели(ТекстЗапроса, Документ, НомерПовтора);

		Если ОтветAPI.ЭтоОшибка Тогда
			Возврат РезультатОшибкиAPI(ОтветAPI.ТекстОшибки);
		КонецЕсли;

		ИтогВалидации = kh_ИнтеграцияИИ.ПроверитьОтветПоСхеме(
			ОтветAPI.ТекстОтвета,
			КонтекстПроверки,
			КоличествоВыполненныхПовторов);

		Результат = ОбработатьИтогВалидации(ИтогВалидации, ОтветAPI.ТекстОтвета, ПорогУверенностиКандидата);

		Если Не Результат.ПовторитьЗапрос Тогда
			Возврат Результат;
		КонецЕсли;

		ПоследнееСообщениеВалидации = Результат.Сообщение;
		КоличествоВыполненныхПовторов = КоличествоВыполненныхПовторов + 1;

	КонецЦикла;

КонецФункции

// Обрабатывает итог валидации ответа модели без дублирования логики валидаторов.
//
// Параметры:
//  ИтогВалидации - Структура - см. КИИ_ВалидацияОтветаИИ.НовыйИтогВалидации
//  ТекстОтветаJSON - Строка - исходный JSON-ответ модели
//  ПорогУверенностиКандидата - Число, Неопределено - минимальный confidence; при Неопределено читается из эксперта
//
// Возвращаемое значение:
//  Структура - см. НовыйРезультатАнализа
//
Функция ОбработатьИтогВалидации(ИтогВалидации, ТекстОтветаJSON, ПорогУверенностиКандидата = Неопределено) Экспорт

	Если ПорогУверенностиКандидата = Неопределено Тогда
		ПорогУверенностиКандидата = КИИ_ЭкспертыИИ.ПорогУверенностиКандидата(
			kh_ИнтеграцияИИ.ЭкспертАнализаНазначенияПлатежа());
	КонецЕсли;

	Результат = НовыйРезультатАнализа();
	Результат.ИтогВалидации = ИтогВалидации;
	Результат.ПовторитьЗапрос = ИтогВалидации.ПовторитьЗапрос;
	Результат.МодельЗапросилаРучнуюПроверку = ПрочитатьNeedsManualReview(ИтогВалидации, ТекстОтветаJSON);

	ЗаполнитьКандидатовПоИтогуВалидации(ИтогВалидации, Результат, ПорогУверенностиКандидата);

	Результат.НужнаРучнаяПроверка = ИтогВалидации.НужнаПроверкаЧеловеком
		Или Результат.МодельЗапросилаРучнуюПроверку
		Или Результат.СпорныеКандидаты.Количество() > 0
		Или ИтогВалидации.ПовторыИсчерпаны;

	Результат.МожноАвтозаполнять = Результат.ПодтвержденныеКандидаты.Количество() > 0
		И Не Результат.ПовторитьЗапрос
		И ИтогВалидации.ПригоденДляПрименения;

	Результат.Сообщение = СформироватьСообщениеРезультата(Результат, ИтогВалидации);

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстСпискаДоговоровКонтрагента(Контрагент)

	Если Не ЗначениеЗаполнено(Контрагент) Тогда
		Возврат НСтр("ru = '(контрагент не указан)'");
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 50
	|	Договоры.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договоры
	|ГДЕ
	|	Договоры.Владелец = &Контрагент
	|	И НЕ Договоры.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Договоры.Наименование";

	Запрос.УстановитьПараметр("Контрагент", Контрагент);

	РезультатЗапроса = Запрос.Выполнить();

	Если РезультатЗапроса.Пустой() Тогда
		Возврат НСтр("ru = '(договоры контрагента не найдены)'");
	КонецЕсли;

	СтрокиСписка = Новый Массив;
	Выборка = РезультатЗапроса.Выбрать();
	НомерСтроки = 0;

	Пока Выборка.Следующий() Цикл

		НомерСтроки = НомерСтроки + 1;

		СтрокиСписка.Добавить(СтрШаблон(
			НСтр("ru = '%1. Наименование: %2'"),
			НомерСтроки,
			Выборка.Наименование));

	КонецЦикла;

	Возврат СтрСоединить(СтрокиСписка, Символы.ПС);

КонецФункции

Функция ПрочитатьNeedsManualReview(ИтогВалидации, ТекстОтветаJSON)

	НормализованныйОтвет = ИтогВалидации.НормализованныйОтвет;

	Если НормализованныйОтвет <> Неопределено
		И НормализованныйОтвет.Свойство("needsManualReview") Тогда

		Возврат НормализованныйОтвет.needsManualReview = Истина;

	КонецЕсли;

	ОтветJSON = РазобратьJSONОтвета(ТекстОтветаJSON);

	Если ОтветJSON = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Не ОтветJSON.Свойство("needsManualReview") Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат ОтветJSON.needsManualReview = Истина;

КонецФункции

Функция МаксимальноеКоличествоПовторовАнализа()

	Возврат 5;

КонецФункции

Функция РезультатИсчерпаныПовторы(ПоследнееСообщение)

	Результат = НовыйРезультатАнализа();
	Результат.НужнаРучнаяПроверка = Истина;

	Если Не ПустаяСтрока(ПоследнееСообщение) Тогда
		Результат.Сообщение = ПоследнееСообщение;
	Иначе
		Результат.Сообщение = НСтр("ru = 'Исчерпан лимит повторных запросов к модели. Требуется ручная обработка.'");
	КонецЕсли;

	Возврат Результат;

КонецФункции

Функция РазобратьJSONОтвета(ТекстОтветаJSON)

	Если ПустаяСтрока(ТекстОтветаJSON) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Попытка
		Возврат ОбщегоНазначения.JSONВЗначение(ТекстОтветаJSON, , Ложь);
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

Процедура ЗаполнитьКандидатовПоИтогуВалидации(ИтогВалидации, Результат, ПорогУверенностиКандидата)

	НормализованныйОтвет = ИтогВалидации.НормализованныйОтвет;

	Если НормализованныйОтвет = Неопределено
		Или Не НормализованныйОтвет.Свойство("candidates") Тогда

		Возврат;

	КонецЕсли;

	Кандидаты = НормализованныйОтвет.candidates;

	Если ТипЗнч(Кандидаты) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;

	Индекс = 0;

	Для Каждого Кандидат Из Кандидаты Цикл

		ВалидацияКандидатаПройдена = КандидатПодтвержден(ИтогВалидации, Индекс, Кандидат);

		Если ВалидацияКандидатаПройдена
			И УверенностьКандидатаДостаточна(Кандидат, ПорогУверенностиКандидата) Тогда

			Договор = ДоговорКандидатаИзНормализованногоОтвета(Кандидат);

			Если Не ЗначениеЗаполнено(Договор) Тогда
				Продолжить;
			КонецЕсли;

			СтрокаКандидата = Новый Структура;
			СтрокаКандидата.Вставить("Индекс", Индекс);
			СтрокаКандидата.Вставить("Договор", Договор);
			СтрокаКандидата.Вставить("Сумма", Кандидат.amount);
			Результат.ПодтвержденныеКандидаты.Добавить(СтрокаКандидата);

		ИначеЕсли ВалидацияКандидатаПройдена
			И Не УверенностьКандидатаДостаточна(Кандидат, ПорогУверенностиКандидата) Тогда

			СпорныйКандидат = Новый Структура;
			СпорныйКандидат.Вставить("Индекс", Индекс);
			СпорныйКандидат.Вставить("Класс", КлассНизкойУверенностиКандидата());
			СпорныйКандидат.Вставить("Сообщение", СообщениеНизкойУверенностиКандидата(Кандидат, ПорогУверенностиКандидата));
			Результат.СпорныеКандидаты.Добавить(СпорныйКандидат);

		ИначеЕсли ЕстьСпорнаяПроверкаКандидата(ИтогВалидации, Индекс) Тогда

			СпорныйКандидат = Новый Структура;
			СпорныйКандидат.Вставить("Индекс", Индекс);
			СпорныйКандидат.Вставить("Класс", КлассПроверкиКандидата(ИтогВалидации, Индекс));
			СпорныйКандидат.Вставить("Сообщение", СообщениеПроверкиКандидата(ИтогВалидации, Индекс));
			Результат.СпорныеКандидаты.Добавить(СпорныйКандидат);

		КонецЕсли;

		Индекс = Индекс + 1;

	КонецЦикла;

КонецПроцедуры

Функция КандидатПодтвержден(ИтогВалидации, Индекс, Кандидат)

	Если ТипЗнч(Кандидат) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ДоговорКандидатаИзНормализованногоОтвета(Кандидат)) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Не Кандидат.Свойство("amount") Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Кандидат.amount) Тогда
		Возврат Ложь;
	КонецЕсли;

	ПутьДоговор = СтрШаблон("candidates.%1.contract", Индекс);
	ПутьСумма = СтрШаблон("candidates.%1.amount", Индекс);

	Возврат ПроверкаПоляПройдена(ИтогВалидации, ПутьДоговор)
		И ПроверкаПоляПройдена(ИтогВалидации, ПутьСумма);

КонецФункции

// Возвращает ссылку на договор из нормализованного кандидата после подстановки PAY_CTR.
//
// Параметры:
//  Кандидат - Структура - элемент массива candidates из НормализованныйОтвет
//
// Возвращаемое значение:
//  СправочникСсылка.ДоговорыКонтрагентов, Неопределено
//
Функция ДоговорКандидатаИзНормализованногоОтвета(Кандидат)

	Если ТипЗнч(Кандидат) <> Тип("Структура")
		Или Не Кандидат.Свойство("contract") Тогда

		Возврат Неопределено;

	КонецЕсли;

	ЗначениеПоля = Кандидат.contract;

	Если ТипЗнч(ЗначениеПоля) = Тип("СправочникСсылка.ДоговорыКонтрагентов")
		И ЗначениеЗаполнено(ЗначениеПоля) Тогда

		Возврат ЗначениеПоля;

	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Функция ЗначениеConfidenceКандидата(Кандидат)

	Если ТипЗнч(Кандидат) <> Тип("Структура")
		Или Не Кандидат.Свойство("confidence") Тогда

		Возврат Неопределено;

	КонецЕсли;

	ЗначениеПоля = Кандидат.confidence;

	Если ТипЗнч(ЗначениеПоля) <> Тип("Число") Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат ЗначениеПоля;

КонецФункции

Функция УверенностьКандидатаДостаточна(Кандидат, ПорогУверенностиКандидата)

	Confidence = ЗначениеConfidenceКандидата(Кандидат);

	Если Confidence = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Confidence >= ПорогУверенностиКандидата;

КонецФункции

Функция КлассНизкойУверенностиКандидата()

	Возврат Перечисления.КИИ_КлассыРезультатаВалидацииОтветаИИ.ОтсутствующаяИнформация;

КонецФункции

Функция СообщениеНизкойУверенностиКандидата(Кандидат, ПорогУверенностиКандидата)

	Confidence = ЗначениеConfidenceКандидата(Кандидат);
	ТекстConfidence = НСтр("ru = '(не указано)'");

	Если Confidence <> Неопределено Тогда
		ТекстConfidence = Формат(Confidence, "ЧДЦ=2; ЧРД=.; ЧГ=");
	КонецЕсли;

	Возврат СтрШаблон(
		НСтр("ru = 'Уверенность модели (%1) ниже порога эксперта (%2)'"),
		ТекстConfidence,
		Формат(ПорогУверенностиКандидата, "ЧДЦ=2; ЧРД=.; ЧГ="));

КонецФункции

Функция ЕстьСпорнаяПроверкаКандидата(ИтогВалидации, Индекс)

	ПрефиксПути = СтрШаблон("candidates.%1.", Индекс);
	КлассПройдена = Перечисления.КИИ_КлассыРезультатаВалидацииОтветаИИ.ПройденаВалидация;

	Для Каждого Проверка Из ИтогВалидации.Проверки Цикл

		Если Не СтрНачинаетсяС(Проверка.ПутьКПолю, ПрефиксПути) Тогда
			Продолжить;
		КонецЕсли;

		Если Проверка.Класс <> КлассПройдена Тогда
			Возврат Истина;
		КонецЕсли;

	КонецЦикла;

	Возврат Ложь;

КонецФункции

Функция ПроверкаПоляПройдена(ИтогВалидации, ПутьКПолю)

	КлассПройдена = Перечисления.КИИ_КлассыРезультатаВалидацииОтветаИИ.ПройденаВалидация;
	Проверка = НайтиПроверкуПоПути(ИтогВалидации, ПутьКПолю);

	Если Проверка = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Проверка.Класс = КлассПройдена;

КонецФункции

Функция НайтиПроверкуПоПути(ИтогВалидации, ПутьКПолю)

	Для Каждого Проверка Из ИтогВалидации.Проверки Цикл

		Если Проверка.ПутьКПолю = ПутьКПолю Тогда
			Возврат Проверка;
		КонецЕсли;

	КонецЦикла;

	Возврат Неопределено;

КонецФункции

Функция КлассПроверкиКандидата(ИтогВалидации, Индекс)

	ПрефиксПути = СтрШаблон("candidates.%1.", Индекс);
	КлассПройдена = Перечисления.КИИ_КлассыРезультатаВалидацииОтветаИИ.ПройденаВалидация;
	ИтоговыйКласс = КлассПройдена;

	Для Каждого Проверка Из ИтогВалидации.Проверки Цикл

		Если Не СтрНачинаетсяС(Проверка.ПутьКПолю, ПрефиксПути) Тогда
			Продолжить;
		КонецЕсли;

		Если Проверка.Класс <> КлассПройдена Тогда
			ИтоговыйКласс = Проверка.Класс;
		КонецЕсли;

	КонецЦикла;

	Возврат ИтоговыйКласс;

КонецФункции

Функция СообщениеПроверкиКандидата(ИтогВалидации, Индекс)

	ПрефиксПути = СтрШаблон("candidates.%1.", Индекс);
	КлассПройдена = Перечисления.КИИ_КлассыРезультатаВалидацииОтветаИИ.ПройденаВалидация;
	Сообщения = Новый Массив;

	Для Каждого Проверка Из ИтогВалидации.Проверки Цикл

		Если Не СтрНачинаетсяС(Проверка.ПутьКПолю, ПрефиксПути) Тогда
			Продолжить;
		КонецЕсли;

		Если Проверка.Класс = КлассПройдена Тогда
			Продолжить;
		КонецЕсли;

		Если Не ПустаяСтрока(Проверка.Сообщение) Тогда
			Сообщения.Добавить(Проверка.Сообщение);
		КонецЕсли;

	КонецЦикла;

	Возврат СтрСоединить(Сообщения, "; ");

КонецФункции

Функция СформироватьСообщениеРезультата(Результат, ИтогВалидации)

	Если Не ПустаяСтрока(ИтогВалидации.Сообщение) Тогда
		Возврат ИтогВалидации.Сообщение;
	КонецЕсли;

	Если Результат.МодельЗапросилаРучнуюПроверку Тогда
		Возврат НСтр("ru = 'Модель запросила ручную проверку результата анализа.'");
	КонецЕсли;

	Если ИтогВалидации.ПовторыИсчерпаны Тогда
		Возврат НСтр("ru = 'Исчерпан лимит повторных запросов к модели. Требуется ручная обработка.'");
	КонецЕсли;

	Возврат "";

КонецФункции

Функция РезультатОшибкиAPI(ТекстОшибки)

	Результат = НовыйРезультатАнализа();
	Результат.ЭтоОшибкаAPI = Истина;
	Результат.ТекстОшибкиAPI = ТекстОшибки;
	Результат.Сообщение = ТекстОшибки;
	Результат.НужнаРучнаяПроверка = Истина;

	Возврат Результат;

КонецФункции

#КонецОбласти
